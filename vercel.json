{
  "functions": { "api/index.py": { "maxDuration": 30 } },
  "public": true,
  "routes": [
    { "src": "/assets/(.*)", "dest": "/public/assets/$1" },
    { "src": "/auth/(.*)", "dest": "/public/auth/$1" },
    { "src": "/images/(.*)", "dest": "/public/images/$1" },
    { "src": "/health", "dest": "/api/index.py" },
    { "src": "/docs", "dest": "/api/index.py" },
    { "src": "/openapi.json", "dest": "/api/index.py" },
    { "src": "/v1/(.*)", "dest": "/api/index.py" },
    { "src": "/internal/(.*)", "dest": "/api/index.py" },
    { "src": "/auth/callback", "dest": "/api/index.py" },
    { "src": "/login.html", "dest": "/public/login.html" },
    { "src": "/dashboard.html", "dest": "/public/dashboard.html" },
    { "src": "/changelog.html", "dest": "/public/changelog.html" },
    { "src": "/(.*\\.html)", "dest": "/public/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "crons": [
    { "path": "/internal/process-retries", "schedule": "0 2 * * *" },
    { "path": "/internal/cleanup", "schedule": "0 2 * * *" }
  ]
}
