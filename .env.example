# SafeRoute API environment configuration
# Copy this file to .env and fill in real values.
#
# IMPORTANT: The app defaults to ENVIRONMENT=production (fail-closed).
# If you want local development convenience, explicitly set ENVIRONMENT=development
# below. In production, ALLOWED_HOSTS, TRUSTED_PROXIES, and ENCRYPTION_KEY
# are required or the app will refuse to start.

# ---------------------------------------------------------------------------
# Required (always)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
DATABASE_URL=postgresql://saferoute:saferoute@localhost:5434/saferoute
API_KEY_SALT=dev-salt-change-in-production

# ---------------------------------------------------------------------------
# Secrets (optional but recommended in production)
# ---------------------------------------------------------------------------
WEBHOOK_SECRET=dev-secret-change-in-production
RETRY_ENDPOINT_SECRET=dev-retry-secret-change-in-production
ENCRYPTION_KEY=dev-encryption-key-change-outside-development

# ---------------------------------------------------------------------------
# App behavior
# ---------------------------------------------------------------------------
ENVIRONMENT=production
FRONTEND_URL=http://localhost:8000
ALLOWED_HOSTS=localhost:8000
TRUSTED_PROXIES=
RETENTION_DAYS=30

# ---------------------------------------------------------------------------
# Outbound / network
# ---------------------------------------------------------------------------
OUTBOUND_HEALTH_CHECK_URL=https://www.google.com/generate_204
FORWARD_TIMEOUT_SECONDS=10.0

# ---------------------------------------------------------------------------
# Rate limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_SECONDS=60
DEFAULT_RATE_LIMIT=30

# ---------------------------------------------------------------------------
# Retry / cleanup
# ---------------------------------------------------------------------------
MAX_RETRIES=3
RETRY_BATCH_SIZE=100
RETRY_CLAIM_STALE_SECONDS=300

# ---------------------------------------------------------------------------
# Logging / storage
# ---------------------------------------------------------------------------
MAX_LOG_BODY_BYTES=10000

# ---------------------------------------------------------------------------
# Disposable email detection
# ---------------------------------------------------------------------------
DISPOSABLE_EMAIL_LIST_URL=https://raw.githubusercontent.com/ivolo/disposable-email-domains/master/index.json

# ---------------------------------------------------------------------------
# Email notifications (Resend)
# ---------------------------------------------------------------------------
RESEND_API_KEY=
EMAIL_FROM=noreply@saferoute.dev
EMAIL_REPLY_TO=

# ---------------------------------------------------------------------------
# Cloudflare Turnstile
# ---------------------------------------------------------------------------
TURNSTILE_SECRET_KEY=

# ---------------------------------------------------------------------------
# Payments (Paystack)
# ---------------------------------------------------------------------------
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_URL=https://saferoute-api.vercel.app/v1/webhooks/paystack

# ---------------------------------------------------------------------------
# Monitoring (Sentry)
# ---------------------------------------------------------------------------
SENTRY_DSN=
APP_VERSION=0.7.0
